# ── Core Django ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default for local dev — no setup needed)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production)
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/quiz_db

# ── Cache ──────────────────────────────────────────────────────────────────────
# Leave empty to use in-memory cache (dev only)
# REDIS_URL=redis://localhost:6379/0

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI Service ─────────────────────────────────────────────────────────────────
# Choose one provider: openai | anthropic | gemini
AI_SERVICE=openai

# OpenAI (https://platform.openai.com/api-keys) — free tier: $5 credit
OPENAI_API_KEY=

# Anthropic (https://console.anthropic.com/) — uses claude-haiku-4-5
ANTHROPIC_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey) — free tier available
GEMINI_API_KEY=
